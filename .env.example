# ═══════════════════════════════════════════════════════════════════
# SCOUT BOT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# REQUIRED: Telegram Bot Setup
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# ═══════════════════════════════════════════════════════════════════
# OPTIONAL: AI Summaries (Free Tier)
# ═══════════════════════════════════════════════════════════════════

# Google Gemini API (free: 1,500 req/day)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Alternative: Groq (free: 30 req/min)
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# ═══════════════════════════════════════════════════════════════════
# OPTIONAL: Additional News Sources
# ═══════════════════════════════════════════════════════════════════

# NewsAPI.org (free: 100 req/day)
NEWSAPI_KEY=your_newsapi_key

# ═══════════════════════════════════════════════════════════════════
# OPTIONAL: Claude Summaries (Paid, use Gemini free instead)
# ═══════════════════════════════════════════════════════════════════
CLAUDE_API_KEY=your_claude_api_key_for_summarization

# ═══════════════════════════════════════════════════════════════════
# NOTE: Only TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID are required.
# Everything else is optional and free.
# ═══════════════════════════════════════════════════════════════════
